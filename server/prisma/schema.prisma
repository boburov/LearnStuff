generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

enum Role {
  USER
}

enum AdminRole {
  PENDING
  ADMIN
  SUPER_ADMIN
}

model User {
  id        Int      @id @default(autoincrement())
  email     String?  @unique
  password  String
  tgId      String   @unique
  username  String?
  role      Role     @default(USER)
  sourceId  Int?
  source    Source?  @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sourceId])
}

model Admin {
  id        Int       @id @default(autoincrement())
  tgId      String    @unique
  phone     String?   @unique
  name      String?
  role      AdminRole @default(PENDING)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Source {
  id        Int      @id @default(autoincrement())
  label     String   @unique
  createdAt DateTime @default(now())
  users     User[]
}
